{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoosalert.local/schemas/report-submission.schema.json",
  "title": "ReportSubmission",
  "description": "Payload for POST /api/report",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "incidentType": {
      "type": "string",
      "minLength": 1,
      "description": "User-selected incident type label."
    },
    "location": {
      "type": "string",
      "minLength": 1,
      "description": "Incident location label or custom value."
    },
    "computingId": {
      "type": "string",
      "minLength": 1,
      "description": "Reporter UVA computing ID."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Optional free-text description. Falls back to incidentType if omitted."
    },
    "latitude": {
      "type": [
        "number",
        "null"
      ],
      "description": "Optional report latitude from map pin."
    },
    "longitude": {
      "type": [
        "number",
        "null"
      ],
      "description": "Optional report longitude from map pin."
    }
  },
  "required": [
    "incidentType",
    "location",
    "computingId"
  ],
  "examples": [
    {
      "incidentType": "Suspicious Activity",
      "location": "Rice Hall (Computer Science)",
      "computingId": "abc123",
      "latitude": 38.0336,
      "longitude": -78.508
    }
  ]
}
